# ============================================
# VPS GDrive Vault — Configuration
# ============================================
# Copy this file to config.env and fill in your values:
#   cp config.env.example config.env
#
# NEVER commit config.env to git (it's in .gitignore)

# --- rclone remote name ---
# Must match your `rclone config` remote name
RCLONE_REMOTE="gdrive"

# --- Google Drive folder structure ---
GDRIVE_HOT_ROOT="GitGDrive"           # Hot sync destination
GDRIVE_ARCHIVE_ROOT="GitGDrive/archive"  # Cold archive destination
GDRIVE_BACKUP_ROOT="VPS-Backup"       # Restic encrypted backup

# --- Source directories ---
# Hot sync: directories to sync every 6 hours
HOT_SYNC_DIRS=(
    "/path/to/your/project"
)

# Cold archive: large/old data to offload
COLD_ARCHIVE_DIRS=(
    "/path/to/old/data"
)

# VPS backup: what restic backs up (encrypted)
BACKUP_DIRS=(
    "/root"
    "/var/www"
)

# --- Restic ---
RESTIC_PASSWORD_FILE="/root/.restic-password"

# --- SQLite databases (snapshot before upload to avoid "source being updated" errors) ---
SQLITE_DBS=(
    # "/path/to/your/database.db"
)

# --- Exclude patterns ---
GLOBAL_EXCLUDES=(
    ".git/**"
    "node_modules/**"
    "__pycache__/**"
    "*.pyc"
    "**/target/**"
    "**/.next/**"
    "**/cache/**"
    "**/out/**"
)

# --- Telegram notifications (leave empty to disable) ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# --- System ---
LOCK_FILE="/tmp/gdrive-operation.lock"
LOG_DIR="/var/log/rclone"

# --- rclone tuning per profile ---
# Hot sync: small files (code, configs)
HOT_TPSLIMIT=12
HOT_CHECKERS=32
HOT_TRANSFERS=4
HOT_PACER_SLEEP="100ms"

# Cold archive: mixed files (repos, large dirs)
COLD_TPSLIMIT=8
COLD_CHECKERS=16
COLD_TRANSFERS=2
COLD_PACER_SLEEP="150ms"

# VPS backup: large restic chunks
BACKUP_TRANSFERS=4
BACKUP_CHECKERS=4
BACKUP_CHUNK_SIZE="64M"
BACKUP_BUFFER_SIZE="128M"

# --- Retention ---
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=2
COLD_ARCHIVE_AGE_DAYS=14    # Remove local dirs older than this after archiving
